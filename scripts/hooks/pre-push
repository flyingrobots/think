#!/usr/bin/env bash
set -euo pipefail

if [[ "${THINK_PRE_PUSH_FULL:-0}" == "1" ]]; then
  echo "pre-push: running full local suite..."
  npm run test:local
  exit 0
fi

echo "pre-push: running fast checks..."
npm run test:fast
echo "pre-push: set THINK_PRE_PUSH_FULL=1 to run npm run test:local before pushing."
