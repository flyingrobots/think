{
  "name": "think",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "bin": {
    "think": "./bin/think.js"
  },
  "scripts": {
    "macos": "swift run --package-path macos ThinkMenuBarApp",
    "test:m1": "node --test test/acceptance/*.test.js",
    "test:benchmarks": "node --test test/benchmarks/*.test.js",
    "test:m2": "swift test --package-path macos",
    "test": "npm run test:m1",
    "test:local": "npm run test:m1 && npm run test:m2",
    "install-hooks": "git config core.hooksPath .githooks",
    "benchmark:browse": "node benchmarks/browse-bootstrap.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@flyingrobots/bijou": "^4.0.0",
    "@flyingrobots/bijou-node": "^4.0.0",
    "@flyingrobots/bijou-tui": "^4.0.0",
    "@git-stunts/alfred": "0.4.0",
    "@git-stunts/git-warp": "14.16.2",
    "@git-stunts/plumbing": "2.8.0"
  }
}
